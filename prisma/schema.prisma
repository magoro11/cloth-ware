generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  cartItems         CartItem[]
  id                String        @id @default(cuid())
  name              String?
  email             String        @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  role              UserRole      @default(CUSTOMER)
  stripeCustomerId  String?
  stripeConnectedId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  accounts          Account[]
  bookings          Booking[]     @relation("BookingCustomer")
  ownedItems        Item[]        @relation("ItemOwner")
  payouts           Payout[]      @relation("OwnerPayouts")
  receivedMessages  Message[]     @relation("MessageRecipient")
  reviewsWritten    Review[]      @relation("ReviewAuthor")
  sentMessages      Message[]     @relation("MessageSender")
  sessions          Session[]
  transactions      Transaction[]
  wishlists         Wishlist[]
}

model Item {
  id                 String              @id @default(cuid())
  ownerId            String
  title              String
  brand              String
  description        String
  category           String
  size               String
  condition          ItemCondition
  rentalPricePerDay  Int
  sellingPrice       Int?
  securityDeposit    Int
  featured           Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  availabilityBlocks AvailabilityBlock[]
  bookings           Booking[]
  cartItems          CartItem[]
  owner              User                @relation("ItemOwner", fields: [ownerId], references: [id])
  images             ItemImage[]
  repairs            RepairLog[]
  reviews            Review[]
  wishlistedBy       Wishlist[]
}

model ItemImage {
  id        String   @id @default(cuid())
  itemId    String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  itemId    String
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Booking {
  id                String        @id @default(cuid())
  itemId            String
  customerId        String
  startDate         DateTime
  endDate           DateTime
  days              Int
  rentalAmount      Int
  securityDeposit   Int
  lateFeeAmount     Int           @default(0)
  commissionAmount  Int
  ownerPayoutAmount Int
  status            BookingStatus @default(PENDING)
  returnDate        DateTime?
  damageReported    Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  customer          User          @relation("BookingCustomer", fields: [customerId], references: [id])
  item              Item          @relation(fields: [itemId], references: [id])
  payout            Payout?
  repairLogs        RepairLog[]
  transactions      Transaction[]

  @@index([itemId, startDate, endDate])
}

model Transaction {
  id                  String          @id @default(cuid())
  bookingId           String?
  userId              String?
  type                TransactionType
  amount              Int
  stripePaymentIntent String?
  stripeTransferId    String?
  metadata            Json?
  createdAt           DateTime        @default(now())
  booking             Booking?        @relation(fields: [bookingId], references: [id])
  user                User?           @relation(fields: [userId], references: [id])
}

model Payout {
  id         String       @id @default(cuid())
  bookingId  String       @unique
  ownerId    String
  amount     Int
  status     PayoutStatus @default(PENDING)
  releasedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  booking    Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  owner      User         @relation("OwnerPayouts", fields: [ownerId], references: [id])
}

model RepairLog {
  id                  String   @id @default(cuid())
  itemId              String
  bookingId           String?
  adminNote           String
  repairCost          Int
  deductedFromDeposit Int
  createdAt           DateTime @default(now())
  booking             Booking? @relation(fields: [bookingId], references: [id])
  item                Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  itemId    String
  authorId  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, createdAt])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  content     String
  createdAt   DateTime @default(now())
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, senderId, createdAt])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  CUSTOMER
  LENDER
  ADMIN
}

enum ItemCondition {
  NEW
  EXCELLENT
  GOOD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELED
  LATE
}

enum TransactionType {
  RENTAL_PAYMENT
  DEPOSIT_HOLD
  COMMISSION
  PAYOUT
  REPAIR_DEDUCTION
  LATE_FEE
}

enum PayoutStatus {
  PENDING
  RELEASED
  FAILED
}
